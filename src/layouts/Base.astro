---
import '../styles/global.css';
const { title = 'Spady｜小樽・銭函のマーケティング支援', description = '北海道・小樽/銭函を拠点に、Meta広告・LINE公式アカウント・SNSの導線設計で地域事業者と海外・教育事業者を支援しています。' } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, 'https://spady.net').href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, 'https://spady.net').href} />
    <meta property="og:image" content="https://spady.net/og.png" />
    <meta property="og:site_name" content="Spady" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;600;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href="/">
          <img class="brand-logo" src="/logo.png" alt="Spady" width="40" height="40" />
          <span class="brand-sub">小樽・銭函｜マーケティング支援</span>
        </a>
        <nav class="nav" id="nav">
          <a href="/#lp-services">サービス</a>
          <a href="/#lp-works">実績</a>
          <a href="/#local">地域・勉強会</a>
          <a href="/#profile">プロフィール</a>
          <a class="btn primary nav-cta" href="/#contact">無料相談</a>
        </nav>
        <button class="menu-btn" id="menuBtn" aria-label="メニューを開く" aria-expanded="false">
          <span></span><span></span>
        </button>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div>
          <img class="footer-logo" src="/logo.png" alt="Spady" width="48" height="48" />
          <p class="note">北海道小樽市銭函｜井上博史</p>
        </div>
        <nav class="footer-nav">
          <a href="#lp-services">留学・語学学校・海外事業の支援</a>
          <a href="#lp-services">サービス一覧</a>
          <a href="/#lp-works">実績</a>
          <a href="#local">地域事業者の支援・勉強会</a>
          <a href="#thoughts">考え方・発信</a>
          <a href="/#profile">プロフィール</a>
        </nav>
        <div class="footer-sns">
          <a href="https://www.threads.com/hiroshiinoue.spady" target="_blank" rel="noopener">Threads</a>
        </div>
      </div>
      <p class="copyright">© Spady</p>
    </footer>

    <script>
      const btn = document.getElementById('menuBtn');
      const nav = document.getElementById('nav');
      btn?.addEventListener('click', () => {
        const open = nav.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(open));
      });
      nav?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => nav.classList.remove('open'))
      );

      const io = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => e.isIntersecting && e.target.classList.add('in')),
        { threshold: 0.12 }
      );
      document.querySelectorAll('.fade').forEach((el) => io.observe(el));
    </script>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(16, 22, 25, 0.9);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--line-dark);
        color: #fff;
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 68px;
      }
      .brand {
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .brand-logo { border-radius: 50%; }
      .brand-sub {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.65);
        letter-spacing: 0.12em;
      }
      .nav { display: flex; align-items: center; gap: 26px; }
      .nav a {
        font-size: 14px;
        text-decoration: none;
        letter-spacing: 0.06em;
        color: rgba(255, 255, 255, 0.85);
        transition: color 0.2s ease;
      }
      .nav a:hover {
        color: var(--gold);
      }
      .nav a.nav-cta:hover {
        color: #fff; /* ボタンはテキストリンク扱いにしない */
      }
      .nav-cta { padding: 10px 22px; font-size: 14px; font-weight: 700; letter-spacing: 0.08em; color: #fff; }
      .menu-btn { display: none; }

      .cta-band {
        background: var(--dark);
        color: #fff;
        text-align: center;
        padding: 96px 24px;
        position: relative;
        overflow: hidden;
      }
      .cta-band::before {
        content: '';
        position: absolute;
        width: 520px;
        height: 520px;
        border-radius: 50%;
        border: 1px solid var(--accent-dim);
        top: -260px;
        right: -160px;
        pointer-events: none;
      }
      .cta-band h2 { font-size: 26px; margin-bottom: 20px; }
      .cta-band p {
        color: rgba(255, 255, 255, 0.78);
        font-size: 15px;
        margin-bottom: 36px;
      }
      .cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
      .btn-line {
        transition: background 0.25s ease, border-color 0.25s ease,
          color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
      }
      .btn-line:hover {
        background: #06c755; /* LINEブランドグリーン */
        border-color: #06c755;
        color: #fff;
        transform: translateY(-3px);
        box-shadow: 0 10px 24px rgba(6, 199, 85, 0.32);
        opacity: 1;
      }
      @media (prefers-reduced-motion: reduce) {
        .btn-line:hover { transform: none; }
      }
      .kari-dark {
        font-size: 10px;
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 3px;
        padding: 0 5px;
        margin-left: 8px;
        vertical-align: middle;
      }

      .site-footer {
        background: #0c1113;
        color: #fff;
        border-top: 1px solid var(--line-dark);
        padding: 56px 0 24px;
      }
      .footer-logo { border-radius: 50%; margin-bottom: 14px; }
      .footer-inner {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 48px;
        align-items: start;
      }
      .footer-nav, .footer-sns { display: grid; gap: 10px; }
      .footer-nav a, .footer-sns a {
        font-size: 13.5px;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.65);
      }
      .site-footer .note { color: rgba(255, 255, 255, 0.55); }
      .copyright {
        text-align: center;
        font-size: 12px;
        color: rgba(255, 255, 255, 0.45);
        margin: 48px 0 0;
      }

      @media (max-width: 760px) {
        .brand-sub { display: none; }
        .nav {
          position: fixed;
          inset: 68px 0 auto 0;
          background: var(--dark);
          border-bottom: 1px solid var(--line-dark);
          flex-direction: column;
          align-items: flex-start;
          padding: 24px;
          gap: 18px;
          display: none;
        }
        .nav.open { display: flex; }
        .menu-btn {
          display: grid;
          gap: 6px;
          background: none;
          border: none;
          padding: 10px;
          cursor: pointer;
        }
        .menu-btn span {
          display: block;
          width: 22px;
          height: 1.5px;
          background: #fff;
        }
        .footer-inner { grid-template-columns: 1fr; gap: 32px; }
      }
    </style>
  </body>
</html>
