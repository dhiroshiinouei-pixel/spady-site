---
import '../styles/global.css';

// ▼ Googleタグマネージャー：コンテナIDを入れると計測が有効になります（例: 'GTM-ABC1234'）
const GTM_ID = 'GTM-NV5VRH3G';

const { title = 'Spady｜集客と採用の導線設計', description = 'Meta広告・LINE公式アカウント・SNSで、集客と採用の導線を設計します。店舗・中小企業から留学・海外事業まで。元Metaマーケティングプロ。北海道・小樽/銭函拠点。', lang = 'ja' } = Astro.props;

// 言語別ラベルとリンク
const home = lang === 'en' ? '/en/' : '/';
const t = lang === 'en'
  ? {
      nav: ['Services', 'Work', 'Local & Seminars', 'Profile'],
      cta: 'Free Consult',
      menuAria: 'Open menu',
      footNote: 'Otaru, Hokkaido, Japan｜Hiroshi Inoue',
      footContact: 'Free consultation / Contact',
      footPrivacy: 'Privacy Policy',
      privacyHref: '/en/privacy/',
      langLabel: '日本語',
      langHref: '/',
      cookieText: 'We use cookies to improve this site and measure advertising.',
      cookieAccept: 'Accept',
      cookieDecline: 'Decline',
    }
  : {
      nav: ['サービス', '実績', '地域・勉強会', 'プロフィール'],
      cta: '無料相談',
      menuAria: 'メニューを開く',
      footNote: '北海道小樽市銭函｜井上博史',
      footContact: '無料相談・お問い合わせ',
      footPrivacy: 'プライバシーポリシー',
      privacyHref: '/privacy/',
      langLabel: 'EN',
      langHref: '/en/',
      cookieText: '当サイトでは、サービス改善と広告の計測のためにCookieを使用します。',
      cookieAccept: '同意する',
      cookieDecline: '同意しない',
    };

// hreflang用の対応URL
const jaPath = lang === 'en' ? (Astro.url.pathname.replace(/^\/en/, '') || '/') : Astro.url.pathname;
const enPath = lang === 'en' ? Astro.url.pathname : ('/en' + Astro.url.pathname).replace(/\/$/, '/') ;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, 'https://spady.net').href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, 'https://spady.net').href} />
    <meta property="og:image" content="https://spady.net/og-20260707-1532.png" />
    <meta name="twitter:image" content="https://spady.net/og-20260707-1532.png" />
    <meta property="og:site_name" content="Spady" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" hreflang="ja" href={new URL(jaPath, 'https://spady.net').href} />
    <link rel="alternate" hreflang="en" href={new URL(enPath, 'https://spady.net').href} />
    <link rel="alternate" hreflang="x-default" href={new URL(jaPath, 'https://spady.net').href} />
    <link rel="icon" type="image/png" href="/favicon.png?v=20260707-1519" />
    <link rel="apple-touch-icon" href="/favicon.png?v=20260707-1519" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;600;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    {GTM_ID && (
      <script is:inline define:vars={{ GTM_ID }}>
        window.dataLayer = window.dataLayer || [];
        window.__loadGTM = function () {
          if (window.__gtmLoaded) return;
          window.__gtmLoaded = true;
          (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
            var f = d.getElementsByTagName(s)[0],
              j = d.createElement(s),
              dl = l != 'dataLayer' ? '&l=' + l : '';
            j.async = true;
            j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
            f.parentNode.insertBefore(j, f);
          })(window, document, 'script', 'dataLayer', GTM_ID);
        };
        try {
          if (localStorage.getItem('spady_cookie_consent') === 'granted') window.__loadGTM();
        } catch (e) {}
      </script>
    )}
  </head>
  <body>
 )}

    <!-- サイト全体の夜空（星・流れ星・色とりどりの飛行機） -->
    <div class="sky" aria-hidden="true">
      <i style="left:6%;top:8%;animation-delay:0s"></i>
      <i style="left:18%;top:22%;animation-delay:1.4s"></i>
      <i style="left:30%;top:6%;animation-delay:2.6s"></i>
      <i style="left:44%;top:16%;animation-delay:0.8s"></i>
      <i style="left:58%;top:9%;animation-delay:3.2s"></i>
      <i style="left:72%;top:20%;animation-delay:1.9s"></i>
      <i style="left:86%;top:7%;animation-delay:2.2s"></i>
      <i style="left:94%;top:30%;animation-delay:0.4s"></i>
      <i style="left:8%;top:42%;animation-delay:2.9s"></i>
      <i style="left:24%;top:55%;animation-delay:1.1s"></i>
      <i style="left:50%;top:47%;animation-delay:3.6s"></i>
      <i style="left:68%;top:58%;animation-delay:0.2s"></i>
      <i style="left:90%;top:50%;animation-delay:2.4s"></i>
      <i style="left:4%;top:70%;animation-delay:1.6s"></i>
      <i style="left:20%;top:84%;animation-delay:3s"></i>
      <i style="left:38%;top:76%;animation-delay:0.6s"></i>
      <i style="left:56%;top:88%;animation-delay:2.1s"></i>
      <i style="left:74%;top:78%;animation-delay:1.2s"></i>
      <i style="left:88%;top:90%;animation-delay:3.4s"></i>
      <i style="left:12%;top:96%;animation-delay:0.9s"></i>
      <i style="left:40%;top:34%;animation-delay:2.7s"></i>
      <i style="left:63%;top:71%;animation-delay:0.3s"></i>
      <i style="left:79%;top:38%;animation-delay:3.8s"></i>
      <i style="left:33%;top:63%;animation-delay:1.7s"></i>
      <span class="shoot sh1"></span>
      <span class="shoot sh2"></span>
      <svg class="fly fly1" viewBox="0 0 40 20"><path d="M2,10 L34,4 L26,10 L34,16 Z" /></svg>
      <svg class="fly fly2" viewBox="0 0 40 20"><path d="M2,10 L34,4 L26,10 L34,16 Z" /></svg>
      <svg class="fly fly3" viewBox="0 0 40 20"><path d="M2,10 L34,4 L26,10 L34,16 Z" /></svg>
    </div>

    <header class="site-header" id="siteHeader">
      <div class="header-inner">
        <a class="brand" href={home}>
          <img class="brand-logo" src="/logo.png?v=20260707-1519" alt="Spady" width="56" height="56" />
        </a>
        <nav class="nav" id="nav">
          <a href={`${home}#lp-services`}>{t.nav[0]}</a>
          <a href={`${home}#lp-works`}>{t.nav[1]}</a>
          <a href={`${home}#local`}>{t.nav[2]}</a>
          <a href={`${home}#profile`}>{t.nav[3]}</a>
          <a class="nav-lang" href={t.langHref}>{t.langLabel}</a>
          <a class="btn primary nav-cta" href={`${home}#contact`}>{t.cta}</a>
        </nav>
        <button class="menu-btn" id="menuBtn" aria-label={t.menuAria} aria-expanded="false">
          <span></span><span></span>
        </button>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <!-- フッターの地平線：宇宙人の基地・散歩する宇宙人・UFO -->
      <div class="footer-scene" aria-hidden="true">
        <svg viewBox="0 0 1200 120" preserveAspectRatio="xMidYMax slice">
          <!-- 基地（ドーム） -->
          <g class="alien-base" transform="translate(150, 120)">
            <path d="M-40 0 A40 40 0 0 1 40 0 Z" class="dome" />
            <path d="M-12 0 A12 12 0 0 1 12 0 Z" class="dome-door" />
            <circle cx="-22" cy="-14" r="3" class="dome-win" />
            <circle cx="22" cy="-14" r="3" class="dome-win" />
            <line x1="0" y1="-40" x2="0" y2="-54" class="dome-ant" />
            <circle cx="0" cy="-57" r="3" class="dome-light" />
          </g>
          <!-- 基地のそばに立つ小さな宇宙人 -->
          <g transform="translate(208, 120)">
            <g class="alien-figure">
              <path d="M-5 0 C-5 -12 5 -12 5 0 Z" class="alien-body" />
              <ellipse cx="-2" cy="-8" rx="1.7" ry="2.2" class="alien-eye" />
              <ellipse cx="2" cy="-8" rx="1.7" ry="2.2" class="alien-eye" />
              <line x1="0" y1="-12" x2="0" y2="-16" class="alien-ant" />
              <circle cx="0" cy="-17" r="1.4" class="alien-ant-tip" />
            </g>
          </g>
          <!-- 散歩する宇宙人 -->
          <g class="alien-walker">
            <g class="walk-bob" transform="translate(0, 120)">
              <path d="M-6 0 C-6 -14 6 -14 6 0 Z" class="alien-body" />
              <ellipse cx="-2.4" cy="-9" rx="2" ry="2.6" class="alien-eye" />
              <ellipse cx="2.4" cy="-9" rx="2" ry="2.6" class="alien-eye" />
              <line x1="0" y1="-14" x2="0" y2="-19" class="alien-ant" />
              <circle cx="0" cy="-20" r="1.6" class="alien-ant-tip" />
            </g>
          </g>
          <!-- UFO -->
          <g class="ufo">
            <g class="ufo-bob">
              <polygon points="-14,8 14,8 26,52 -26,52" class="ufo-beam" />
              <ellipse cx="0" cy="0" rx="26" ry="8" class="ufo-disc" />
              <path d="M-13 -2 A13 10 0 0 1 13 -2 Z" class="ufo-dome" />
              <circle cx="-14" cy="4" r="2" class="ufo-light l1" />
              <circle cx="0" cy="6" r="2" class="ufo-light l2" />
              <circle cx="14" cy="4" r="2" class="ufo-light l3" />
            </g>
          </g>
        </svg>
      </div>
      <div class="wrap footer-inner">
        <div>
          <img class="footer-logo" id="footerLogo" src="/logo.png?v=20260707-1519" alt="Spady" width="52" height="52" />
          <p class="note">{t.footNote}</p>
        </div>
        <nav class="footer-nav">
          <a href={`${home}#contact`}>{t.footContact}</a>
          <a href={t.privacyHref}>{t.footPrivacy}</a>
          <a href={t.langHref}>{t.langLabel}</a>
        </nav>
        <div class="footer-sns">
          <a class="footer-threads" href="https://www.threads.com/hiroshiinoue.spady" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z"/></svg>
            <span>Threads</span>
          </a>
        </div>
      </div>
      <p class="copyright">© Spady</p>
    </footer>

    <!-- ロケット演出（CTAクリックで降下／送信完了で発射） -->
    <div class="rocket-fx" id="rocketFx" aria-hidden="true">
      <svg viewBox="0 0 40 84">
        <path class="rk-body" d="M20 2 C28 14 30 28 30 44 L10 44 C10 28 12 14 20 2 Z" />
        <circle class="rk-win" cx="20" cy="26" r="5" />
        <path class="rk-fin" d="M10 44 L2 60 L10 54 Z" />
        <path class="rk-fin" d="M30 44 L38 60 L30 54 Z" />
        <rect class="rk-base" x="12" y="44" width="16" height="6" rx="2" />
        <path class="rk-flame" d="M20 52 C25 59 25 68 20 78 C15 68 15 59 20 52 Z" />
      </svg>
    </div>

    <div class="cookie-bar" id="cookieBar" hidden>
      <p>{t.cookieText} <a href={t.privacyHref}>{t.footPrivacy}</a></p>
      <div class="cookie-actions">
        <button id="cookieAccept" class="btn primary cookie-accept">{t.cookieAccept}</button>
        <button id="cookieDecline" class="cookie-decline">{t.cookieDecline}</button>
      </div>
    </div>

    <script>
      // 上にスクロールで表示し、止めても表示を維持。下スクロールでのみ隠す
      const header = document.getElementById('siteHeader');
      let lastY = window.scrollY;
      const onScroll = () => {
        const y = window.scrollY;
        if (y <= 120) {
          header.classList.remove('scrolled');
          document.getElementById('nav')?.classList.remove('open');
        } else if (y < lastY - 2) {
          header.classList.add('scrolled'); // 上に戻した：表示
        } else if (y > lastY + 2) {
          header.classList.remove('scrolled'); // 下に進んだ：非表示
          document.getElementById('nav')?.classList.remove('open');
        }
        // 停止中（変化±2px以内）は状態を維持
        lastY = y;
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // モバイルメニュー
      const btn = document.getElementById('menuBtn');
      const nav = document.getElementById('nav');
      btn?.addEventListener('click', () => {
        const open = nav.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(open));
      });
      nav?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => nav.classList.remove('open'))
      );

      // フッターロゴ：クリックでピカッ
      const fl = document.getElementById('footerLogo');
      fl?.addEventListener('click', () => {
        fl.classList.remove('ping');
        void fl.offsetWidth; // 再アニメーションのためのリフロー
        fl.classList.add('ping');
        setTimeout(() => fl.classList.remove('ping'), 750);
      });

      // ロケット演出
      const rocket = document.getElementById('rocketFx');
      const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.__rocket = (mode) => {
        if (!rocket || reduceMotion) return;
        rocket.classList.remove('go', 'launch');
        void rocket.offsetWidth;
        rocket.classList.add(mode === 'launch' ? 'launch' : 'go');
      };
      document.querySelectorAll('a.btn-big[href="#contact"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          e.preventDefault();
          window.__rocket('go');
          document.getElementById('contact')?.scrollIntoView({
            behavior: reduceMotion ? 'auto' : 'smooth',
          });
        });
      });

      // Cookie同意バー
      const cookieBar = document.getElementById('cookieBar');
      let consent = null;
      try { consent = localStorage.getItem('spady_cookie_consent'); } catch (e) {}
      if (!consent && cookieBar) cookieBar.hidden = false;
      document.getElementById('cookieAccept')?.addEventListener('click', () => {
        try { localStorage.setItem('spady_cookie_consent', 'granted'); } catch (e) {}
        window.__loadGTM?.();
        cookieBar.hidden = true;
      });
      document.getElementById('cookieDecline')?.addEventListener('click', () => {
        try { localStorage.setItem('spady_cookie_consent', 'denied'); } catch (e) {}
        cookieBar.hidden = true;
      });

      // 控えめなフェードイン
      const io = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => e.isIntersecting && e.target.classList.add('in')),
        { threshold: 0.12 }
      );
      document.querySelectorAll('.fade').forEach((el) => io.observe(el));
    </script>

    <style>
      /* ---------- 夜空レイヤー ---------- */
      .sky {
        position: fixed;
        inset: 0;
        z-index: -1;
        overflow: hidden;
        pointer-events: none;
      }
      .sky i {
        position: absolute;
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: #fff;
        opacity: 0.15;
        box-shadow: 0 0 3px rgba(190, 225, 255, 0.45);
        animation: skyTwinkle 5.2s ease-in-out infinite;
      }
      @keyframes skyTwinkle {
        0%, 100% { opacity: 0.08; }
        50% { opacity: 0.32; }
      }
      /* 流れ星 */
      .shoot {
        position: absolute;
        width: 100px;
        height: 1.6px;
        border-radius: 2px;
        background: linear-gradient(90deg, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0));
        opacity: 0;
        transform: rotate(148deg);
      }
      .shoot.sh1 { top: 10%; left: 68%; animation: shootStar 11s linear infinite 3s; }
      .shoot.sh2 { top: 48%; left: 28%; animation: shootStar 17s linear infinite 9s; }
      @keyframes shootStar {
        0% { opacity: 0; transform: translate(0, 0) rotate(148deg); }
        1.5% { opacity: 0.9; }
        7% { opacity: 0; transform: translate(-240px, 150px) rotate(148deg); }
        100% { opacity: 0; transform: translate(-240px, 150px) rotate(148deg); }
      }
      /* 色とりどりの飛行機 */
      .fly { position: absolute; width: 36px; opacity: 0; }
      .fly1 { top: 22%; animation: flyby 32s linear infinite; }
      .fly1 path { fill: rgba(196, 178, 235, 0.7); } /* 薄い紫 */
      .fly2 { top: 64%; width: 30px; animation: flybyRev 41s linear infinite 12s; }
      .fly2 path { fill: rgba(197, 232, 165, 0.7); } /* 薄い黄緑 */
      .fly3 { top: 40%; width: 26px; animation: flyby 52s linear infinite 24s; }
      .fly3 path { fill: rgba(172, 221, 240, 0.7); } /* 薄い水色 */
      @keyframes flyby {
        0% { transform: translate(-8vw, 0) rotate(-6deg); opacity: 0; }
        2% { opacity: 0.6; }
        36% { opacity: 0.6; }
        38% { transform: translate(110vw, -12vh) rotate(-6deg); opacity: 0; }
        100% { transform: translate(110vw, -12vh); opacity: 0; }
      }
      @keyframes flybyRev {
        0% { transform: translate(110vw, 0) rotate(186deg); opacity: 0; }
        2% { opacity: 0.6; }
        36% { opacity: 0.6; }
        38% { transform: translate(-10vw, -10vh) rotate(186deg); opacity: 0; }
        100% { transform: translate(-10vw, -10vh); opacity: 0; }
      }

      /* ---------- ヘッダー：FVでは非表示、スクロールで浮き出る ---------- */
      .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 30;
        opacity: 0;
        transform: translateY(-12px);
        pointer-events: none;
        transition: opacity 0.35s ease, transform 0.35s ease;
      }
      .site-header.scrolled {
        opacity: 1;
        transform: none;
        pointer-events: auto;
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
      }
      .brand { display: block; line-height: 0; }
      .brand-logo {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        filter: drop-shadow(0 4px 14px rgba(0, 0, 0, 0.5));
        animation: heartbeat 3.2s ease-in-out infinite;
      }
      @keyframes heartbeat {
        0%, 24%, 100% { transform: scale(1); }
        6% { transform: scale(1.14); }
        12% { transform: scale(1); }
        18% { transform: scale(1.09); }
      }
      .nav {
        display: flex;
        align-items: center;
        gap: 4px;
        background: rgba(13, 19, 22, 0.62);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--line-dark);
        border-radius: 999px;
        padding: 6px 8px 6px 20px;
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);
      }
      .nav a {
        font-size: 13.5px;
        text-decoration: none;
        letter-spacing: 0.05em;
        color: rgba(255, 255, 255, 0.85);
        padding: 8px 12px;
        transition: color 0.2s ease;
      }
      .nav a:hover { color: var(--gold); }
      .nav-lang {
        font-weight: 700;
        letter-spacing: 0.12em;
        border-left: 1px solid var(--line-dark);
        margin-left: 4px;
      }
      .nav-cta {
        padding: 10px 22px;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: #fff;
        border-radius: 999px;
        margin-left: 6px;
      }
      .nav a.nav-cta:hover { color: #fff; }
      .menu-btn { display: none; }

      /* ---------- フッター ---------- */
      .site-footer {
        position: relative;
        background: rgba(3, 7, 9, 0.5);
        color: #fff;
        border-top: 1px solid var(--line-dark);
        padding: 56px 0 24px;
      }
      /* ---- フッター上の地平線シーン ---- */
      .footer-scene {
        position: absolute;
        left: 0;
        right: 0;
        top: -1px;
        transform: translateY(-100%);
        height: 120px;
        overflow: hidden;
        pointer-events: none;
      }
      .footer-scene svg { width: 100%; height: 100%; display: block; }
      .dome { fill: rgba(255, 255, 255, 0.05); stroke: rgba(255, 255, 255, 0.3); stroke-width: 1.2; }
      .dome-door { fill: rgba(13, 19, 22, 0.8); stroke: rgba(255, 255, 255, 0.25); stroke-width: 1; }
      .dome-win { fill: rgba(47, 157, 216, 0.7); }
      .dome-ant { stroke: rgba(255, 255, 255, 0.4); stroke-width: 1.2; }
      .dome-light { fill: var(--gold); animation: domeBlink 2.4s ease-in-out infinite; }
      @keyframes domeBlink { 0%, 100% { opacity: 0.25; } 50% { opacity: 1; } }
      .alien-body { fill: #8ee6a8; }
      .alien-eye { fill: #101619; }
      .alien-ant { stroke: #8ee6a8; stroke-width: 1.2; }
      .alien-ant-tip { fill: var(--gold); }
      .alien-figure { animation: alienWave 3.6s ease-in-out infinite; transform-origin: 0 0; }
      @keyframes alienWave { 0%, 100% { transform: rotate(0deg); } 50% { transform: rotate(-6deg); } }
      .alien-walker { animation: alienWalk 30s linear infinite; }
      @keyframes alienWalk {
        from { transform: translateX(-40px); }
        to { transform: translateX(1240px); }
      }
      .walk-bob { animation: walkBob 0.45s ease-in-out infinite alternate; transform-origin: 50% 100%; }
      @keyframes walkBob {
        from { transform: translate(0, 120px) rotate(-4deg); }
        to { transform: translate(0, 117px) rotate(4deg); }
      }
      .ufo { animation: ufoFly 40s linear infinite; }
      @keyframes ufoFly {
        from { transform: translate(1260px, 34px); }
        to { transform: translate(-80px, 34px); }
      }
      .ufo-bob { animation: ufoBob 2.6s ease-in-out infinite; }
      @keyframes ufoBob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }
      .ufo-disc { fill: #cdd8e1; stroke: rgba(255, 255, 255, 0.5); stroke-width: 0.8; }
      .ufo-dome { fill: rgba(140, 200, 255, 0.55); }
      .ufo-beam { fill: rgba(255, 215, 94, 0.08); animation: beamPulse 3.2s ease-in-out infinite; }
      @keyframes beamPulse { 0%, 100% { opacity: 0.25; } 50% { opacity: 1; } }
      .ufo-light { fill: var(--gold); }
      .ufo-light.l1 { animation: domeBlink 0.9s ease-in-out infinite; }
      .ufo-light.l2 { animation: domeBlink 0.9s ease-in-out 0.3s infinite; }
      .ufo-light.l3 { animation: domeBlink 0.9s ease-in-out 0.6s infinite; }
      .footer-logo {
        border-radius: 50%;
        margin-bottom: 14px;
        cursor: pointer;
        animation: heartbeat 3.2s ease-in-out 1.1s infinite;
      }
      .footer-logo.ping { animation: logoPing 0.7s ease; }
      @keyframes logoPing {
        0% { filter: brightness(1); transform: scale(1); }
        30% {
          filter: brightness(2) drop-shadow(0 0 28px rgba(255, 215, 94, 0.95));
          transform: scale(1.18);
        }
        100% { filter: brightness(1); transform: scale(1); }
      }
      .footer-inner {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 48px;
        align-items: start;
      }
      .footer-nav, .footer-sns { display: grid; gap: 10px; }
      .footer-nav a {
        font-size: 13.5px;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.65);
        transition: color 0.2s ease;
      }
      .footer-nav a:hover { color: var(--gold); }
      .footer-threads {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 13.5px;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.65);
        transition: color 0.2s ease;
      }
      .footer-threads svg { width: 17px; height: 17px; }
      .footer-threads:hover { color: var(--gold); }
      .site-footer .note { color: rgba(255, 255, 255, 0.55); }
      .copyright {
        text-align: center;
        font-size: 12px;
        color: rgba(255, 255, 255, 0.45);
        margin: 48px 0 0;
      }

      /* ---------- ロケット演出 ---------- */
      .rocket-fx {
        position: fixed;
        left: 50%;
        top: -110px;
        width: 46px;
        margin-left: -23px;
        z-index: 70;
        pointer-events: none;
        opacity: 0;
      }
      .rocket-fx svg { display: block; width: 100%; height: auto; }
      .rk-body { fill: #e8eef4; stroke: rgba(0, 0, 0, 0.15); stroke-width: 0.6; }
      .rk-win { fill: var(--blue); stroke: #fff; stroke-width: 1.2; }
      .rk-fin { fill: var(--accent); }
      .rk-base { fill: #c6d0d8; }
      .rk-flame {
        fill: var(--gold);
        transform-origin: 20px 52px;
        animation: rkFlick 0.13s ease-in-out infinite alternate;
      }
      @keyframes rkFlick {
        from { transform: scaleY(0.75) scaleX(0.9); }
        to { transform: scaleY(1.15) scaleX(1.05); }
      }
      /* CTAクリック：ノーズを下に向けてフォームへ降下 */
      .rocket-fx.go {
        transform: rotate(180deg);
        animation: rocketRide 1.15s cubic-bezier(0.45, 0, 0.7, 1) forwards;
      }
      @keyframes rocketRide {
        0% { top: -110px; opacity: 0; }
        10% { opacity: 1; }
        88% { opacity: 1; }
        100% { top: 112vh; opacity: 0; }
      }
      /* 送信完了：下から上へ発射 */
      .rocket-fx.launch {
        top: auto;
        bottom: -120px;
        animation: rocketLaunch 1.5s cubic-bezier(0.5, 0, 0.75, 0.4) forwards;
      }
      @keyframes rocketLaunch {
        0% { bottom: -120px; opacity: 0; }
        10% { opacity: 1; }
        88% { opacity: 1; }
        100% { bottom: 114vh; opacity: 0; }
      }
      .rocket-fx.go svg, .rocket-fx.launch svg {
        animation: rkWiggle 0.16s ease-in-out infinite alternate;
      }
      @keyframes rkWiggle {
        from { transform: translateX(-1.5px); }
        to { transform: translateX(1.5px); }
      }

      /* ---------- Cookie同意バー ---------- */
      .cookie-bar {
        position: fixed;
        right: 20px;
        bottom: 20px;
        left: auto;
        width: min(92vw, 460px);
        z-index: 60;
        background: rgba(13, 19, 22, 0.94);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--line-dark);
        border-radius: 14px;
        padding: 18px 20px;
        box-shadow: 0 14px 40px rgba(0, 0, 0, 0.5);
      }
      .cookie-bar p {
        margin: 0 0 14px;
        font-size: 13px;
        line-height: 1.8;
        color: var(--white-soft);
      }
      .cookie-bar p a { color: rgba(255, 255, 255, 0.8); }
      .cookie-bar p a:hover { color: var(--gold); }
      .cookie-actions { display: flex; align-items: center; gap: 18px; }
      .cookie-accept {
        border: none;
        cursor: pointer;
        padding: 10px 24px;
        font-size: 13.5px;
        font-weight: 700;
      }
      .cookie-decline {
        background: none;
        border: none;
        cursor: pointer;
        font-family: var(--font-goth);
        font-size: 13px;
        color: rgba(255, 255, 255, 0.55);
        text-decoration: underline;
        text-underline-offset: 3px;
        padding: 4px;
        transition: color 0.2s ease;
      }
      .cookie-decline:hover { color: var(--gold); }
      @media (max-width: 760px) {
        .cookie-bar { right: 12px; left: 12px; bottom: 12px; width: auto; }
      }

      @media (prefers-reduced-motion: reduce) {
        .sky i, .sky .fly, .sky .shoot, .brand-logo, .footer-logo, .rocket-fx, .rk-flame, .alien-walker, .walk-bob, .ufo, .ufo-bob, .ufo-beam, .ufo-light, .dome-light, .alien-figure { animation: none !important; }
        .sky .fly, .sky .shoot { opacity: 0; }
      }

      /* ---------- モバイル：スケルトンバー＋浮遊ロゴ/ハンバーガー ---------- */
      @media (max-width: 760px) {
        .header-inner { padding: 12px 14px; }
        .brand-logo { width: 52px; height: 52px; }
        .nav {
          position: fixed;
          top: 74px;
          right: 14px;
          left: auto;
          flex-direction: column;
          align-items: stretch;
          gap: 4px;
          background: rgba(13, 19, 22, 0.85);
          border-radius: 16px;
          padding: 14px;
          display: none;
          box-shadow: 0 14px 40px rgba(0, 0, 0, 0.5);
        }
        .nav.open { display: flex; }
        .nav a { padding: 10px 12px; }
        .nav-cta { margin: 6px 0 0; text-align: center; }
        .menu-btn {
          display: grid;
          place-content: center;
          gap: 6px;
          width: 48px;
          height: 48px;
          border-radius: 50%;
          background: rgba(13, 19, 22, 0.62);
          backdrop-filter: blur(12px);
          -webkit-backdrop-filter: blur(12px);
          border: 1px solid var(--line-dark);
          box-shadow: 0 6px 20px rgba(0, 0, 0, 0.45);
          cursor: pointer;
          padding: 0;
        }
        .menu-btn span {
          display: block;
          width: 20px;
          height: 1.6px;
          background: #fff;
        }
        .footer-inner { grid-template-columns: 1fr; gap: 32px; }
      }
    </style>
  </body>
</html>
