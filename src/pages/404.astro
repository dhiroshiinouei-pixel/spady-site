---
import Base from '../layouts/Base.astro';
---
<Base title="ページが見つかりません｜Spady" description="お探しのページは見つかりませんでした。">
  <div class="band dark">
    <section class="nf">
      <div class="wrap" style="text-align:center;">
        <p class="nf-code">404</p>
        <h1>ページが見つかりません</h1>
        <p class="nf-text">サイトをリニューアルしたため、以前のページは移動または削除されています。</p>
        <a class="btn primary" href="/ryugaku/">トップページへ</a>
      </div>
    </section>
  </div>
  <style>
    .nf { padding: 140px 0 160px; }
    .nf-code {
      font-family: var(--font-min);
      font-size: 90px;
      color: var(--accent);
      line-height: 1;
      margin: 0 0 16px;
    }
    .nf h1 { font-size: 26px; color: #fff; margin-bottom: 16px; }
    .nf-text { color: var(--white-soft); margin-bottom: 36px; }
  </style>
</Base>
