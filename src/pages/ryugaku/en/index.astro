  <script>
    // フォーム送信（Cloudflare Pages Functions → Lark連携）
    const form = document.querySelector('.form-card');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('.form-submit');
        btn.disabled = true;
        btn.textContent = 'Sending…';
        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          if (!res.ok) throw new Error('failed');
          // GTM計測：フォーム送信成功イベント
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'form_submit_success', form_name: 'free_consult' });
          form.innerHTML =
            '<p class="form-done">Sent. I will get back to you within 2 business days.<br>Thank you!</p>';
        } catch {
          btn.disabled = false;
          btn.textContent = 'Book a Free Consultation';
          alert('Something went wrong. Please try again in a moment.');
        }
      });
    }

    // GTM計測：LINEボタンのクリック
    document.querySelectorAll('.btn-line').forEach((el) => {
      el.addEventListener('click', () => {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'line_click' });
      });
    });

    // 数字カウントアップ（80社・100アカウント）
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    document.querySelectorAll('.cnt').forEach((el) => {
      const target = parseInt(el.dataset.target, 10);
      const io = new IntersectionObserver((entries) => {
        if (!entries[0].isIntersecting) return;
        io.disconnect();
        if (reduce) { el.textContent = String(target); return; }
        const start = performance.now();
        const dur = 1400;
        const tick = (now) => {
          const p = Math.min((now - start) / dur, 1);
          el.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3))));
          if (p < 1) requestAnimationFrame(tick);
        };
        el.textContent = '0';
        requestAnimationFrame(tick);
      });
      io.observe(el);
    });
  </script>

