    .e-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex: none; }
    .lp-sec { padding: 104px 0; }
    .band.dark.alt { background: rgba(2, 9, 13, 0.55); }
    .lp-sec h2 { font-size: 30px; margin-bottom: 44px; color: #fff; }
    .h2-sub {
      display: inline-block;
      font-family: var(--font-goth);
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.1em;
      color: rgba(255, 255, 255, 0.55);
      margin-left: 16px;
      vertical-align: 2px;
    }
    .narrow { max-width: 760px; }
    em { font-style: normal; color: var(--gold); }
    .sp { display: none; }

    /* ---------- 入場アニメーション（ヒーロー） ---------- */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: none; }
    }
    .rise { animation: fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both; }
    .d1 { animation-delay: 0.05s; }
    .d2 { animation-delay: 0.15s; }
    .d3 { animation-delay: 0.3s; }
    .d4 { animation-delay: 0.45s; }
    .d5 { animation-delay: 0.65s; }

    /* スクロール時のカード段差（Baseの.fade/.inを利用） */
    .grid2 > .fade:nth-child(2), .x-list > .fade:nth-child(2), .grid3 > .fade:nth-child(2) { transition-delay: 0.08s; }
    .grid2 > .fade:nth-child(3), .x-list > .fade:nth-child(3), .grid3 > .fade:nth-child(3) { transition-delay: 0.16s; }
    .grid2 > .fade:nth-child(4), .x-list > .fade:nth-child(4) { transition-delay: 0.24s; }

    /* ---------- ヒーロー ---------- */
    .lp-hero {
      position: relative;
      overflow: hidden;
      min-height: 100svh;
      display: flex;
      align-items: center;
      padding: 100px 0 96px;
    }
    .lp-hero .eyebrow {
      font-size: 15.5px;
      letter-spacing: 0.14em;
      color: rgba(255, 255, 255, 0.88);
    }
    .fv-logo {
      position: absolute;
      top: 18px;
      left: 22px;
      z-index: 6;
      width: 84px;
      height: 84px;
      border-radius: 50%;
      border: 3px solid rgba(255, 255, 255, 0.92);
      box-shadow: 0 0 26px rgba(237, 28, 36, 0.55);
      animation: eyeSway 7s ease-in-out infinite;
    }
    @keyframes eyeSway {
      0%, 100% { transform: rotate(0deg) scale(1); }
      30% { transform: rotate(10deg) scale(1.05); }
      60% { transform: rotate(-6deg) scale(1); }
    }
    .lp-hero::before {
      content: '';
      position: absolute;
      width: 860px;
      height: 860px;
      border-radius: 50%;
      border: 1px solid var(--accent-dim);
      top: -220px;
      right: -280px;
      pointer-events: none;
      animation: drift 22s ease-in-out infinite;
    }
    @keyframes drift {
      0%, 100% { transform: translate(0, 0); }
      50% { transform: translate(-18px, 26px); }
    }
    .lp-hero::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(220px 140px at 12% 92%, rgba(255, 196, 130, 0.07), transparent 70%),
        radial-gradient(180px 120px at 34% 100%, rgba(255, 180, 110, 0.05), transparent 70%),
        radial-gradient(260px 160px at 78% 96%, rgba(255, 200, 140, 0.06), transparent 70%);
    }
    .lp-hero-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 56px;
      align-items: center;
    }
    .lp-hero h1 { font-size: 44px; line-height: 1.6; color: #fff; margin-bottom: 24px; }
    .lp-sub { font-size: 16px; color: var(--white-soft); margin-bottom: 32px; }
    .lp-btns { display: flex; gap: 16px; flex-wrap: wrap; margin-top: 34px; }

    /* ---------- 宇宙から見た地球 ---------- */
    .hero-visual { max-width: 440px; margin: 0 auto; }
    .hero-visual svg { width: 100%; height: auto; display: block; }
    .atmo-glow { fill: none; stroke: rgba(110, 190, 255, 0.5); stroke-width: 12; }
    .atmo-line { fill: none; stroke: rgba(165, 218, 255, 0.5); stroke-width: 1.4; }
    .spin-land { animation: spinGlobe 11s linear infinite; }
    .spin-clouds { animation: spinGlobe 18s linear infinite; }
    @keyframes spinGlobe { to { transform: translateX(-464px); } }
    .land path, .land ellipse {
      fill: url(#landGrad);
      stroke: rgba(225, 250, 232, 0.32);
      stroke-width: 0.8;
    }
    .clouds ellipse { fill: rgba(255, 255, 255, 0.2); }
    .route-base { fill: none; stroke: rgba(255, 215, 94, 0.28); stroke-width: 1.5; }
    .route-flow {
      fill: none;
      stroke: var(--gold);
      stroke-width: 1.6;
      stroke-dasharray: 5 9;
      stroke-linecap: round;
      animation: dashflow 2.8s linear infinite;
      opacity: 0.95;
    }
    @keyframes dashflow { to { stroke-dashoffset: -140; } }
    .traveler { fill: var(--gold); filter: drop-shadow(0 0 5px rgba(255, 215, 94, 0.9)); }
    .node { fill: var(--accent); }
    .dot-blue { fill: var(--blue); }
    .dot-green { fill: var(--green); }
    .halo { fill: none; stroke-width: 1.5; }
    .halo-red { stroke: var(--accent); }
    .halo-blue { stroke: var(--blue); }
    .halo-green { stroke: var(--green); }
    .node-label {
      font-family: 'Zen Kaku Gothic New', sans-serif;
      font-size: 13px;
      letter-spacing: 0.3em;
      fill: rgba(255, 255, 255, 0.9);
    }
    .spady-sat {
      animation: satFloat 4.2s ease-in-out infinite;
      transform-origin: 384px 142px;
    }
    @keyframes satFloat {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-9px) rotate(7deg); }
    }
    .sat-halo { fill: none; stroke: var(--accent); stroke-width: 1.5; }
    .sat-ring { fill: none; stroke: rgba(255, 255, 255, 0.85); stroke-width: 2; }
    .orbit-ring { stroke: rgba(255, 255, 255, 0.12); stroke-width: 1; stroke-dasharray: 2 7; }
    .orbit-sat { opacity: 0.95; }
    .sat-body { fill: #e6edf3; stroke: rgba(255, 255, 255, 0.5); stroke-width: 0.6; }
    .sat-ant { stroke: rgba(255, 255, 255, 0.8); stroke-width: 1; }
    .sat-ant-tip { fill: #fff; }
    .orbit-sat .sat-panel { stroke: rgba(0, 0, 0, 0.3); stroke-width: 0.5; }
    .os-gold .sat-panel { fill: var(--gold); }
    .os-blue .sat-panel { fill: var(--blue); }
    .os-gold { filter: drop-shadow(0 0 5px rgba(255, 215, 94, 0.55)); }
    .os-blue { filter: drop-shadow(0 0 5px rgba(47, 157, 216, 0.55)); }
    .spady-sat image { filter: drop-shadow(0 0 10px rgba(237, 28, 36, 0.55)); }

    /* ---------- 浮遊する宇宙飛行士（EMU風） ---------- */
    #lp-services { position: relative; overflow: hidden; }
    .astro-float {
      position: absolute;
      top: 56px;
      right: 6.5%;
      width: 112px;
      pointer-events: none;
      animation: astroDrift 8s ease-in-out infinite;
      opacity: 0.96;
      filter: drop-shadow(0 6px 18px rgba(0, 0, 0, 0.45));
    }
    .astro-float svg { display: block; width: 100%; height: auto; }
    @keyframes astroDrift {
      0%, 100% { transform: translate(0, 0) rotate(-7deg); }
      50% { transform: translate(-15px, 18px) rotate(8deg); }
    }
    .as-line { stroke: rgba(20, 32, 40, 0.25); stroke-width: 1; }
    .as-limb {
      fill: none;
      stroke: #e6edf3;
      stroke-width: 11;
      stroke-linecap: round;
    }
    .as-stripe { stroke: var(--accent); stroke-width: 4.5; stroke-linecap: round; }
    .as-glove, .as-boot { fill: #8f9ca6; stroke: rgba(20, 32, 40, 0.3); stroke-width: 0.8; }
    .as-seam { stroke: rgba(20, 32, 40, 0.14); stroke-width: 1; fill: none; }
    .as-hose { fill: none; stroke: #9fb2c1; stroke-width: 3.5; stroke-linecap: round; }
    .as-plug-b { fill: var(--blue); }
    .as-plug-r { fill: var(--accent); }
    .as-dcm { fill: #8b98a3; stroke: rgba(20, 32, 40, 0.35); stroke-width: 0.8; }
    .as-knob-g { fill: var(--gold); }
    .as-knob-b { fill: var(--blue); }
    .as-slit { fill: rgba(16, 22, 25, 0.55); }
    .as-ring { fill: #9aa7b1; stroke: rgba(20, 32, 40, 0.3); stroke-width: 0.8; }
    .as-glare {
      fill: none;
      stroke: rgba(255, 255, 255, 0.6);
      stroke-width: 2.4;
      stroke-linecap: round;
    }
    .as-earth-ref { fill: rgba(80, 190, 200, 0.4); }
    .as-ant { stroke: rgba(230, 237, 243, 0.9); stroke-width: 1.6; }
    .as-ant-tip { fill: var(--gold); }
    .as-badge { fill: var(--accent); stroke: rgba(255, 255, 255, 0.85); stroke-width: 1.2; }

    /* ---------- 3色アクセント ---------- */
    .e-dot.e-blue { background: var(--blue); }
    .e-dot.e-green { background: var(--green); }
    .card.c-blue { border-top: 3px solid var(--blue); }
    .card.c-green { border-top: 3px solid var(--green); }
    .card.c-red { border-top: 3px solid var(--accent); }
    .flow .num.n-red { border-color: var(--accent); color: var(--accent); }
    .flow .num.n-blue { border-color: var(--blue); color: var(--blue); }
    .flow .num.n-green { border-color: var(--green); color: var(--green); }

    /* ---------- FV内の権威性・数字 ---------- */
    .cred {
      display: flex;
      align-items: flex-end;
      gap: 40px;
      flex-wrap: wrap;
      margin-top: 36px;
      padding-top: 26px;
      border-top: 1px solid var(--line-dark);
    }
    .cred-item strong {
      display: block;
      font-family: var(--font-min);
      font-weight: 700;
      font-size: 31px;
      color: #fff;
      line-height: 1.15;
      letter-spacing: 0.02em;
    }
    .cred-item span {
      display: block;
      font-size: 11.5px;
      color: rgba(255, 255, 255, 0.58);
      letter-spacing: 0.05em;
      margin-top: 5px;
    }
    .cred-meta { padding-left: 14px; border-left: 3px solid var(--gold); }
    .cred-meta strong { color: var(--gold); font-size: 35px; text-shadow: 0 0 22px rgba(255, 215, 94, 0.35); }
    .c-num .cnt { font-size: 46px; }
    .c-num i { font-style: normal; font-size: 15px; color: rgba(255, 255, 255, 0.85); margin-left: 3px; }
    .n-blue .cnt { color: var(--blue); text-shadow: 0 0 18px rgba(47, 157, 216, 0.45); }
    .n-green .cnt { color: var(--green); text-shadow: 0 0 18px rgba(6, 199, 85, 0.45); }

    /* ---------- 悩み ---------- */
    .x-list { list-style: none; padding: 0; margin: 0 0 56px; display: grid; gap: 14px; }
    .x-list li {
      background: var(--dark-2);
      border: 1px solid var(--line-dark);
      border-radius: var(--radius);
      padding: 18px 22px 18px 52px;
      position: relative;
      font-size: 15px;
      color: var(--white-soft);
    }
    .x-list li::before { content: '✕'; position: absolute; left: 22px; color: var(--accent); font-weight: 700; }
    .x-list b { color: var(--gold); font-weight: 700; }
    .bridge { border-left: 2px solid var(--accent); padding-left: 24px; }
    .bridge-lead {
      font-family: var(--font-min);
      font-size: 22px;
      color: #fff;
      line-height: 1.9;
      margin-bottom: 14px;
    }
    .bridge-body { color: var(--white-soft); font-size: 15px; margin: 0; }

    /* ---------- 強み ---------- */
    .reason {
      display: grid;
      grid-template-columns: 84px 1fr;
      gap: 24px;
      padding: 32px 0;
      border-bottom: 1px solid var(--line-dark);
    }
    .reason:first-of-type { border-top: 1px solid var(--line-dark); }
    .reason .num { font-family: var(--font-min); font-size: 34px; color: var(--accent); line-height: 1; padding-top: 6px; }
    .reason h3 { font-size: 22px; font-weight: 700; color: #fff; margin-bottom: 8px; }
    .reason p { font-size: 15px; color: var(--white-soft); margin: 0; }

    /* ---------- グリッド・カード ---------- */
    .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .card { transition: transform 0.3s ease, border-color 0.3s ease, opacity 0.7s ease; }
    .card:hover { transform: translateY(-4px); border-color: rgba(255, 255, 255, 0.3); }
    .industries {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 28px;
    }
    .industries span {
      font-size: 12.5px;
      letter-spacing: 0.05em;
      color: var(--white-soft);
      border: 1px solid var(--line-dark);
      border-radius: 999px;
      padding: 6px 14px;
    }
    .card.featured { margin-bottom: 20px; border-color: rgba(237, 28, 36, 0.45); }
    .card.featured:hover { border-color: rgba(237, 28, 36, 0.8); }
    .metric-lp { font-family: var(--font-min); font-size: 18px; color: #fff !important; margin-bottom: 8px; }
    .more.on-dark { color: #fff; }
    .more.on-dark:hover { color: var(--gold); border-bottom-color: var(--gold); }

    .work-card .logo-slot {
      height: 140px;
      margin-bottom: 20px;
      border-radius: 6px;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .logo-slot img {
      max-height: 104px; /* 枠140px − 上下余白 */
      max-width: calc(100% - 48px);
      object-fit: contain;
    }

    /* ---------- 地域店舗の支援事例 ---------- */
    .case-sec { padding: 84px 0; }
    .case-sec h2 { margin-bottom: 32px; }
    .case-card {
      background: var(--dark-2);
      border: 1px solid var(--line-dark);
      border-radius: var(--radius);
      padding: 30px 32px;
    }
    .case-head {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
    }
    .case-ic { flex: none; width: 40px; height: 40px; }
    .case-ic svg { display: block; width: 100%; height: 100%; overflow: visible; }
    .cs-bowl { fill: #1c262b; stroke: rgba(255, 255, 255, 0.55); stroke-width: 1.6; }
    .cs-plate { stroke: rgba(255, 255, 255, 0.35); stroke-width: 1.6; stroke-linecap: round; }
    .cs-steam {
      fill: none;
      stroke: rgba(255, 255, 255, 0.45);
      stroke-width: 1.6;
      stroke-linecap: round;
      animation: steamRise 2.6s ease-in-out infinite;
    }
    .cs-steam.st2 { animation-delay: 0.8s; }
    .cs-steam.st3 { animation-delay: 1.6s; }
    @keyframes steamRise {
      0%, 100% { opacity: 0.2; transform: translateY(0); }
      50% { opacity: 0.75; transform: translateY(-2.5px); }
    }
    .case-head h3 { font-size: 18px; color: #fff; margin: 0; }
    .case-tag {
      display: inline-block;
      font-family: var(--font-goth);
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.08em;
      color: rgba(255, 255, 255, 0.55);
      border: 1px solid var(--line-dark);
      border-radius: 999px;
      padding: 3px 10px;
      margin-left: 12px;
      vertical-align: 2px;
    }
    .case-card > p { font-size: 14.5px; color: var(--white-soft); margin: 0 0 12px; }
    .case-quote {
      font-family: var(--font-min);
      font-size: 18px !important;
      color: #fff !important;
      line-height: 1.9;
      border-left: 2px solid var(--green);
      padding-left: 16px;
      margin: 18px 0 14px !important;
    }
    .case-note { font-size: 12px !important; color: rgba(255, 255, 255, 0.45) !important; margin: 0 !important; }
    .card.case-wide { grid-column: 1 / -1; }
    .case-wide .metric-lp { border-left: 2px solid var(--green); padding-left: 14px; }

    /* ---------- 地域・発信・プロフィール ---------- */
    .seminar-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 40px; align-items: center; }
    .seminar-fig { margin: 0; }
    .seminar-fig img {
      width: 100%;
      height: auto;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      border-radius: var(--radius);
      border: 1px solid var(--line-dark);
      display: block;
    }
    .seminar-fig figcaption {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.5);
      letter-spacing: 0.08em;
      margin-top: 10px;
      text-align: right;
    }
    .embed-ph { min-height: 180px; text-align: center; display: grid; place-content: center; gap: 10px; }
    .embed-ph p { margin: 0; font-size: 13px; }
    .sns-links { display: flex; gap: 28px; flex-wrap: wrap; margin-top: 36px; align-items: center; }
    .lp-profile { display: grid; grid-template-columns: 200px 1fr; gap: 48px; align-items: center; }
    .lp-profile-mark {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      border: 2px solid rgba(255, 255, 255, 0.18);
      overflow: hidden;
    }
    .lp-profile-mark img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .lp-profile p { color: var(--white-soft); }
    .profile-links { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
    .pro-moon {
      width: 54px;
      height: 54px;
      margin-top: 6px;
      animation: moonFloat 5.5s ease-in-out infinite;
    }
    .pro-moon svg {
      display: block;
      width: 100%;
      height: 100%;
      filter: drop-shadow(0 0 12px rgba(255, 244, 200, 0.45));
    }
    .moon-marks ellipse { fill: rgba(158, 144, 100, 0.32); }
    .moon-drift { animation: moonDrift 11s linear infinite; }
    @keyframes moonDrift { to { transform: translateX(-48px); } }
    @keyframes moonFloat {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-5px) rotate(4deg); }
    }
    .threads-chip {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      margin-top: 6px;
      padding: 8px 18px 8px 14px;
      border: 1px solid var(--line-dark);
      border-radius: 999px;
      text-decoration: none;
      font-size: 13.5px;
      letter-spacing: 0.04em;
      color: var(--white-soft);
      transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    }
    .threads-chip svg { width: 19px; height: 19px; }
    .threads-chip:hover {
      color: var(--gold);
      border-color: var(--gold);
      transform: translateY(-2px);
    }

    /* ---------- なぜ、この活動をしているのか ---------- */
    .why {
      margin-top: 44px;
      background: var(--dark-2);
      border: 1px solid var(--line-dark);
      border-radius: var(--radius);
      transition: border-color 0.25s ease;
    }
    .why[open], .why:hover { border-color: rgba(255, 215, 94, 0.45); }
    .why summary {
      list-style: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 20px 26px;
      -webkit-tap-highlight-color: transparent;
    }
    .why summary::-webkit-details-marker { display: none; }
    .why-title {
      flex: 1;
      font-family: var(--font-min);
      font-size: 17.5px;
      font-weight: 600;
      color: #fff;
      letter-spacing: 0.04em;
    }
    .why summary::after {
      content: '+';
      flex: none;
      width: 32px;
      height: 32px;
      display: grid;
      place-items: center;
      border: 1px solid var(--gold);
      border-radius: 50%;
      color: var(--gold);
      font-size: 20px;
      font-weight: 400;
      transition: transform 0.3s ease;
    }
    .why[open] summary::after { content: '−'; transform: rotate(180deg); }
    .why-body { padding: 2px 26px 24px; }
    .why[open] .why-body { animation: whyReveal 0.5s ease both; }
    .why-office-gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
      margin: 26px 0 8px;
    }
    .why-office-gallery figure { margin: 0; }
    .why-office-gallery img {
      width: 100%;
      height: auto;
      object-fit: contain;
      border-radius: 10px;
      box-shadow: 0 4px 16px rgba(27, 37, 64, 0.1);
    }
    .why-office-gallery figcaption {
      margin-top: 8px;
      font-size: 11px;
      color: rgba(255, 255, 255, 0.62);
      text-align: center;
      letter-spacing: 0.03em;
    }
    .why-office-caption {
      margin-top: 10px;
      font-size: 12px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.54);
      text-align: center;
      letter-spacing: 0.04em;
    }
    @keyframes whyReveal {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: none; }
    }
    .why-body p {
      font-size: 14.5px;
      line-height: 2.1;
      color: var(--white-soft);
      margin: 0 0 16px;
      max-width: 720px;
    }
    .why-body p:last-of-type { margin-bottom: 0; }
    .why-sign { display: flex; justify-content: flex-end; margin-top: 14px; }
    .why-sign img {
      display: block;
      width: 46px;
      height: 46px;
      animation: signSpin 7s linear infinite;
    }
    @keyframes signSpin { to { transform: rotate(360deg); } }

    /* ---------- 流れ ---------- */
    .flow { list-style: none; padding: 0; margin: 0; display: grid; }
    .flow li {
      display: grid;
      grid-template-columns: 56px 1fr;
      gap: 24px;
      padding: 26px 0;
      border-bottom: 1px solid var(--line-dark);
    }
    .flow li:first-child { border-top: 1px solid var(--line-dark); }
    .flow .num {
      width: 44px;
      height: 44px;
      border-radius: 50%;
